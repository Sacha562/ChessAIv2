# ChessAIv2 formatting rules — the machine-enforceable half of cpp-style-guide.md (§6).
# Tuned to match the existing src/ code so `clang-format -i` is near-idempotent.
# Run before finishing any C++ change:  clang-format -i src/<file>.hpp src/<file>.cpp
---
Language:        Cpp
Standard:        c++20
BasedOnStyle:    LLVM

# Indentation — 4 spaces, never tabs (§6).
IndentWidth:     4
TabWidth:        4
UseTab:          Never
ContinuationIndentWidth: 4
NamespaceIndentation: None
IndentCaseLabels: true
AccessModifierOffset: -4

# Line length (§6).
ColumnLimit:     100

# Braces — attached / K&R (§6).
BreakBeforeBraces: Attach

# Short-form allowances — keep the codebase's inline accessors and one-line guards.
AllowShortFunctionsOnASingleLine: Inline
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortBlocksOnASingleLine: Always
AllowShortLoopsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: false
AllowShortEnumsOnASingleLine: false

# Pointers/references bind to the type: const Board&, Board* (§6).
PointerAlignment: Left
ReferenceAlignment: Left
QualifierAlignment: Leave          # do not reorder const/volatile (west const kept as written)

# Vertical alignment — the aligned constant/field blocks in types.hpp & search.hpp (§6).
AlignConsecutiveAssignments:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
AlignConsecutiveDeclarations:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: false
AlignTrailingComments: true
AlignAfterOpenBracket: Align
AlignOperands: true

# Spacing.
SpaceBeforeParens: ControlStatements
SpaceAfterCStyleCast: false
SpacesInParentheses: false
SpacesInAngles: false
Cpp11BracedListStyle: true

# Includes — preserve the hand-ordered own-header-first grouping (§4); do NOT sort across groups.
SortIncludes: false
IncludeBlocks:   Preserve

# Misc.
FixNamespaceComments: true         # enforce `} // namespace engine`
MaxEmptyLinesToKeep: 1
KeepEmptyLinesAtTheStartOfBlocks: false
BinPackParameters: true
BinPackArguments: true
ReflowComments:  true
