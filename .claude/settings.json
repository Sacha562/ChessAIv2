{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/check_docs_sync.py --event post-tool",
            "timeout": 30,
            "statusMessage": "Checking doc companion..."
          },
          {
            "type": "command",
            "command": "python scripts/check_cpp_style.py --event post-tool",
            "timeout": 30,
            "statusMessage": "Checking C++ style..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/check_docs_sync.py --event stop",
            "timeout": 30,
            "statusMessage": "Verifying docs are in sync..."
          },
          {
            "type": "command",
            "command": "python scripts/check_cpp_style.py --event stop",
            "timeout": 30,
            "statusMessage": "Verifying C++ style..."
          }
        ]
      }
    ]
  }
}
